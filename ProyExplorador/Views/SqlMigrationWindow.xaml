<Window x:Class="ProyExplorador.Views.SqlMigrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Migración de Datos" Height="400" Width="600" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Selector de tipo de BD -->
        <StackPanel>
            <TextBlock Text="Tipo de Base de Datos:" Margin="0,0,0,8" Foreground="#FF000000" FontWeight="Bold" FontSize="12"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="RdoSqlServer" Content="SQL Server" Margin="0,0,20,0" IsChecked="True" BorderBrush="#FFBA9B9B" FontWeight="Bold" Foreground="#FF000000"/>
                <RadioButton x:Name="RdoMySQL" Content="MySQL (HeidiSQL)" Foreground="#FF000000" BorderBrush="#FF9F9F9F" FontWeight="Bold" Checked="RdoMySQL_Checked" Grid.IsSharedSizeScope="True" Background="Black"/>
            </StackPanel>
        </StackPanel>

        <!-- Cadena de conexión -->
        <StackPanel Grid.Row="1" Margin="0,12,0,0">
            <TextBlock x:Name="LblConnection" Text="Cadena de conexión (SQL Server):" Margin="0,0,0,4" 
                       Foreground="#FF000000" FontWeight="Bold"/>
            <TextBox x:Name="TxtConnectionString" Height="70" TextWrapping="Wrap" AcceptsReturn="True"/>
            <Button x:Name="BtnTestConnection" Content="Probar conexión" Width="120" Margin="0,4,0,0" 
                    Click="BtnTestConnection_Click" Background="#FF4CAF50" Foreground="White"/>
        </StackPanel>

        <!-- Nombre de tabla -->
        <StackPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock Text="Nombre de tabla destino:" Margin="0,0,0,4" Foreground="#FF11326F" FontWeight="Bold"/>
            <TextBox x:Name="TxtTableName" Height="26"/>
        </StackPanel>

        <!-- Información -->
        <TextBlock Grid.Row="3" x:Name="LblInfo" Text="" Margin="0,12,0,0" Foreground="#FF666666" FontSize="11" TextWrapping="Wrap"/>

        <!-- Botones -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,12,0,0">
            <Button x:Name="BtnCancel" Content="Cancelar" Width="90" Margin="0,0,8,0" Click="BtnCancel_Click" 
                    FontWeight="Bold" Background="#FFFF3333" Foreground="White"/>
            <Button x:Name="BtnOk" Content="Migrar" Width="90" Click="BtnOk_Click" 
                    Background="#FF2C00FF" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
