<Window x:Class="ProyExplorador.Views.SqlDataViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Visualizador de Datos SQL"
        Width="1000" Height="600"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI">

    <Border CornerRadius="14"
            Background="#1a1a2e"
            BorderBrush="#1EFFFFFF"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="8" Opacity="0.55"/>
        </Border.Effect>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="Visualizador de Datos SQL" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Carga y visualiza tablas desde SQL Server" FontSize="12" Foreground="#999" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Connection Info & Buttons -->
            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Tabla:" VerticalAlignment="Center" Foreground="White" Margin="0,0,8,0"/>
                    <TextBox x:Name="TxtTableName" Width="200" Height="32" Padding="8,6" 
                             Background="#0F0F12" Foreground="White" BorderBrush="#333" BorderThickness="1" 
                             Text="cliente" VerticalAlignment="Center"/>
                </StackPanel>

                <Button x:Name="BtnLoadData" Grid.Column="1" Content="Cargar Datos" Width="120" Height="32" Margin="8,0,0,0"
                        Background="#6366F1" Foreground="White" Click="BtnLoadData_Click"
                        Cursor="Hand" FontWeight="Bold"/>

                <Button x:Name="BtnRefresh" Grid.Column="2" Content="Actualizar" Width="100" Height="32" Margin="8,0,0,0"
                        Background="#3B82F6" Foreground="White" Click="BtnRefresh_Click"
                        Cursor="Hand" FontWeight="Bold"/>

                <Button x:Name="BtnExport" Grid.Column="3" Content="Exportar CSV" Height="32" Margin="20,0,0,0"
                        Background="#10B981" Foreground="White" Click="BtnExport_Click"
                        Cursor="Hand" FontWeight="Bold"/>
            </Grid>

            <!-- DataGrid -->
            <Border Grid.Row="2" Background="#0F0F12" CornerRadius="8" BorderBrush="#333" BorderThickness="1" Padding="1">
                <DataGrid x:Name="DataGridResults" 
                          Background="#0F0F12"
                          Foreground="White"
                          BorderThickness="0"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          GridLinesVisibility="All"
                          HorizontalGridLinesBrush="#222"
                          VerticalGridLinesBrush="#222">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#1a1a2e"/>
                            <Setter Property="Foreground" Value="#6366F1"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="8,6"/>
                            <Setter Property="BorderBrush" Value="#333"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="8,6"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </DataGrid.CellStyle>
                </DataGrid>
            </Border>

            <!-- Status Bar -->
            <Grid Grid.Row="3" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="TxtStatus" Grid.Column="0" Text="Listo" Foreground="#666" FontSize="12"/>
                <TextBlock x:Name="TxtRecordCount" Grid.Column="1" Text="Registros: 0" Foreground="#666" FontSize="12"/>
            </Grid>
        </Grid>
    </Border>
</Window>
